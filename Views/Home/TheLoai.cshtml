@{
    ViewData["Title"] = "Thể loại truyện";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/home-the-loai.css" asp-append-version="true" />
}

<div class="container my-5">
    <div class="row">
        <div class="col-12">
            <h1 class="text-center mb-5"><i class="fas fa-tags me-3"></i>Các thể loại truyện</h1>
        </div>
    </div>

    <div class="row g-3 justify-content-center">
        <div class="col-xl-2 col-lg-3 col-md-4 col-sm-6 mb-3">
            <a asp-controller="Truyen" asp-action="TimKiem" asp-route-theLoai="Hành động" class="genre-card text-decoration-none h-100 d-block">
                <div class="card border-0 bg-transparent text-center p-4 h-100 d-flex flex-column justify-content-center hover-scale rounded-4 shadow-sm">
                    <i class="fas fa-fire fa-3x text-danger mb-3"></i>
                    <h6 class="fw-bold mb-1">Hành động</h6>
                    <small class="text-muted">Truyện gay cấn</small>
                </div>
            </a>
        </div>

        <div class="col-xl-2 col-lg-3 col-md-4 col-sm-6 mb-3">
            <a asp-controller="Truyen" asp-action="TimKiem" asp-route-tuKhoa="Phiêu lưu" class="genre-card text-decoration-none h-100 d-block">
