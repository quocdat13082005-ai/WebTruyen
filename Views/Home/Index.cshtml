@{
    ViewData["Title"] = "Trang chủ";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@model Truyen.Models.HomeIndexViewModel

@functions {
    public static string TrangThaiHienThi(string? trangThai)
    {
        return string.IsNullOrWhiteSpace(trangThai) ? "Đang ra" : trangThai;
    }

    public static string TrangThaiCssClass(string? trangThai)
    {
        if (string.IsNullOrWhiteSpace(trangThai))
        {
            return string.Empty;
        }

        return trangThai.Trim().ToLowerInvariant() switch
        {
            "full" => "story-card__cta--success",
            "ngừng phát hành" => "story-card__cta--danger",
            "ngung phat hanh" => "story-card__cta--danger",
            _ => string.Empty
        };
    }
}

<div class="container-fluid py-5 bg-light">
@if (Context.Session.GetString("VaiTro") != null)
    {
        var vaiTro = Context.Session.GetString("VaiTro");
        var vaiTroDisplay = vaiTro switch
        {
            "NguoiDoc" => "Người đọc",
            "TacGia" => "Tác giả",
            "Admin" => "Quản trị viên",
            _ => vaiTro ?? "Không xác định"
        };
        
        <div class="alert alert-success alert-dismissible fade show mb-5 mx-auto" style="max-width: 800px;" role="alert">
            <i class="fas fa-check-circle me-2"></i>
            <strong>Xin chào @Context.Session.GetString("HoTen")! (@vaiTroDisplay)</strong>
            <a href="/Home/Profile" class="alert-link">Xem thông tin cá nhân & nạp xu →</a>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }



    <!-- TRUYỆN HOT -->
    <section class="mb-5 home-story-section">
        <h2 class="text-center mb-4">
            <i class="fas fa-fire text-danger me-2"></i>TRUYỆN HOT <span class="badge bg-danger">@Model.TruyenHot.Count</span>
        </h2>
        <div class="position-relative">
            <button class="btn btn-dark position-absolute top-50 start-0 translate-middle-y z-3 slider-nav slider-prev" data-slider="hot">❮</button>
            <div class="slider-container overflow-hidden px-4">
                <div class="slider-track d-flex" id="hotTrack">
                    @foreach (var truyen in Model.TruyenHot)
                    {
                        <article class="home-story-slide flex-shrink-0 mx-3 story-card">
                            <a asp-controller="Truyen" asp-action="ChiTiet" asp-route-id="@truyen.MaTruyen" class="story-card__link">
                                <img src="@(string.IsNullOrWhiteSpace(truyen.AnhBia) ? "/img/default-cover.jpg" : truyen.AnhBia)"
                                     class="story-card__image"
                                     alt="@truyen.TenTruyen" />
                                <div class="story-card__body">
                                    <h3 class="story-card__title">@truyen.TenTruyen</h3>
                                    <p class="story-card__genre">@truyen.TheLoai</p>
                                    <div class="story-card__meta">
                                        <span class="story-card__badge story-card__badge--views">
                                            <i class="fas fa-eye me-1"></i>@truyen.LuotXem
                                        </span>
                                        <span class="story-card__badge story-card__badge--likes">
                                            <i class="fas fa-heart me-1"></i>@truyen.LuotThich
                                        </span>
                                    </div>
                                    <span class="story-card__cta @TrangThaiCssClass(truyen.TrangThai)">@TrangThaiHienThi(truyen.TrangThai)</span>
                                </div>
                            </a>
                        </article>
                    }
                </div>
            </div>
            <button class="btn btn-dark position-absolute top-50 end-0 translate-middle-y z-3 slider-nav slider-next" data-slider="hot">❯</button>
        </div>
    </section>

    <!-- TRUYỆN HAY -->
    <section class="mb-5 home-story-section">
        <h2 class="text-center mb-4">
            <i class="fas fa-star text-warning me-2"></i>TRUYỆN HAY <span class="badge bg-warning text-dark">@Model.TruyenHay.Count</span>
        </h2>
        <div class="position-relative">
            <button class="btn btn-dark position-absolute top-50 start-0 translate-middle-y z-3 slider-nav slider-prev" data-slider="hay">❮</button>
            <div class="slider-container overflow-hidden px-4">
                <div class="slider-track d-flex" id="hayTrack">
                    @foreach (var truyen in Model.TruyenHay)
                    {
                        <article class="home-story-slide flex-shrink-0 mx-3 story-card">
                            <a asp-controller="Truyen" asp-action="ChiTiet" asp-route-id="@truyen.MaTruyen" class="story-card__link">
                                <img src="@(string.IsNullOrWhiteSpace(truyen.AnhBia) ? "/img/default-cover.jpg" : truyen.AnhBia)"
                                     class="story-card__image"
                                     alt="@truyen.TenTruyen" />
                                <div class="story-card__body">
                                    <h3 class="story-card__title">@truyen.TenTruyen</h3>
                                    <p class="story-card__genre">@truyen.TheLoai</p>
                                    <div class="story-card__meta">
                                        <span class="story-card__badge story-card__badge--views">
                                            <i class="fas fa-eye me-1"></i>@truyen.LuotXem
                                        </span>
                                        <span class="story-card__badge story-card__badge--likes">
                                            <i class="fas fa-heart me-1"></i>@truyen.LuotThich
                                        </span>
                                    </div>
                                    <span class="story-card__cta @TrangThaiCssClass(truyen.TrangThai)">@TrangThaiHienThi(truyen.TrangThai)</span>
                                </div>
                            </a>
                        </article>
                    }
                </div>
            </div>
            <button class="btn btn-dark position-absolute top-50 end-0 translate-middle-y z-3 slider-nav slider-next" data-slider="hay">❯</button>
        </div>
    </section>

    <!-- TRUYỆN FULL -->
    <section class="mb-5 home-story-section">
        <h2 class="text-center mb-4">
            <i class="fas fa-check-double text-success me-2"></i>TRUYỆN FULL <span class="badge bg-success">@Model.TruyenFull.Count</span>
        </h2>
        <div class="position-relative">
            <button class="btn btn-dark position-absolute top-50 start-0 translate-middle-y z-3 slider-nav slider-prev" data-slider="full">❮</button>
            <div class="slider-container overflow-hidden px-4">
                <div class="slider-track d-flex" id="fullTrack">
                    @foreach (var truyen in Model.TruyenFull)
                    {
                        <article class="home-story-slide flex-shrink-0 mx-3 story-card">
                            <a asp-controller="Truyen" asp-action="ChiTiet" asp-route-id="@truyen.MaTruyen" class="story-card__link">
                                <img src="@(string.IsNullOrWhiteSpace(truyen.AnhBia) ? "/img/default-cover.jpg" : truyen.AnhBia)"
                                     class="story-card__image"
                                     alt="@truyen.TenTruyen" />
                                <div class="story-card__body">
                                    <h3 class="story-card__title">@truyen.TenTruyen</h3>
                                    <p class="story-card__genre">@truyen.TheLoai</p>
                                    <div class="story-card__meta">
                                        <span class="story-card__badge story-card__badge--views">
                                            <i class="fas fa-eye me-1"></i>@truyen.LuotXem
                                        </span>
                                        <span class="story-card__badge story-card__badge--likes">
                                            <i class="fas fa-heart me-1"></i>@truyen.LuotThich
                                        </span>
                                    </div>
                                    <span class="story-card__cta @TrangThaiCssClass(truyen.TrangThai)">@TrangThaiHienThi(truyen.TrangThai)</span>
                                </div>
                            </a>
                        </article>
                    }
                </div>
            </div>
            <button class="btn btn-dark position-absolute top-50 end-0 translate-middle-y z-3 slider-nav slider-next" data-slider="full">❯</button>
        </div>
    </section>
</div>
