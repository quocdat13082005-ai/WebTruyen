@model Truyen.Models.TuSachCaNhanViewModel

@{
    ViewData["Title"] = Model.TieuDe;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/truyen-tu-sach-ca-nhan.css" asp-append-version="true" />
}

<div class="container py-5">
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mb-4">
        <div>
            <h1 class="fw-bold mb-2">@Model.TieuDe</h1>
            <p class="text-muted mb-0">@Model.MoTa</p>
        </div>
        <a asp-controller="Home" asp-action="Profile" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left me-2"></i>Quay lại hồ sơ
        </a>
    </div>

    @if (Model.Truyens.Any())
    {
        <div class="row g-4">
            @foreach (var truyen in Model.Truyens)
            {
                <div class="col-xl-3 col-lg-4 col-md-6">
                    <a asp-controller="Truyen" asp-action="ChiTiet" asp-route-id="@truyen.MaTruyen" class="text-decoration-none">
                        <div class="card h-100 border-0 shadow-sm hover-card">
                            <img src="@(string.IsNullOrWhiteSpace(truyen.AnhBia) ? "/img/default-cover.jpg" : truyen.AnhBia)"
                                 class="card-img-top"
                                 style="height:320px; object-fit:cover;"
                                 alt="@truyen.TenTruyen" />
                            <div class="card-body">
                                <h5 class="fw-bold text-dark">@truyen.TenTruyen</h5>
                                <p class="text-muted small mb-2">@truyen.TheLoai</p>
                                <div class="d-flex gap-2 flex-wrap">
                                    <span class="badge bg-warning text-dark">
                                        <i class="fas fa-eye me-1"></i>@truyen.LuotXem
                                    </span>
                                    <span class="badge bg-danger">
                                        <i class="fas fa-heart me-1"></i>@truyen.LuotThich
                                    </span>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-light border">
            Danh sách hiện đang trống.
        </div>
    }

    @if (Model.GoiYTruyens.Any())
    {
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-3 mt-5 mb-4">
            <div>
                <h2 class="h4 fw-bold mb-1">18 truyện gợi ý</h2>
                <p class="text-muted mb-0">Gợi ý thêm các truyện nổi bật để bạn khám phá tiếp.</p>
            </div>
            <a asp-controller="Truyen" asp-action="DanhSachTruyen" class="btn btn-outline-dark">
                Xem tất cả
            </a>
        </div>

        <div class="row g-4">
            @foreach (var truyen in Model.GoiYTruyens)
            {
                <div class="col-xl-2 col-lg-3 col-md-4 col-sm-6">
                    <a asp-controller="Truyen" asp-action="ChiTiet" asp-route-id="@truyen.MaTruyen" class="text-decoration-none">
                        <div class="card h-100 border-0 shadow-sm hover-card">
                            <img src="@(string.IsNullOrWhiteSpace(truyen.AnhBia) ? "/img/default-cover.jpg" : truyen.AnhBia)"
                                 class="card-img-top suggestion-cover"
                                 alt="@truyen.TenTruyen" />
                            <div class="card-body">
                                <h6 class="fw-bold text-dark suggestion-title">@truyen.TenTruyen</h6>
                                <p class="text-muted small mb-2 suggestion-genre">@truyen.TheLoai</p>
                                <div class="d-flex gap-2 flex-wrap">
                                    <span class="badge bg-warning text-dark">
                                        <i class="fas fa-eye me-1"></i>@truyen.LuotXem
                                    </span>
                                    <span class="badge bg-danger">
                                        <i class="fas fa-heart me-1"></i>@truyen.LuotThich
                                    </span>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    }
</div>
