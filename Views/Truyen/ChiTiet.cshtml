@model Truyen.Models.ChiTietTruyenViewModel

@{
    ViewData["Title"] = Model.Truyen.TenTruyen;
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5">

    <!-- Hero Section -->
    <div class="row g-4 mb-5">

        <div class="col-lg-4">
            <img src="@(Model.Truyen.AnhBia ?? "/img/default-cover.jpg")"
                 class="img-fluid rounded-4 shadow-lg"
                 style="height:500px;object-fit:cover;width:100%;"
                 alt="@Model.Truyen.TenTruyen" />
        </div>

        <div class="col-lg-8">

            <h1 class="display-4 fw-bold mb-4">
                @Model.Truyen.TenTruyen
            </h1>

            <div class="mb-4">
                <h5 class="fw-bold text-primary">
                    <i class="fas fa-user me-2"></i>
                    @(Model.Truyen.TacGia ?? "N/A")
                </h5>

                <small class="text-muted">
                    <i class="fas fa-calendar me-1"></i>
                    @Model.Truyen.NgayDang.ToString("dd/MM/yyyy")
                </small>
            </div>

            <!-- Stats -->
            <div class="d-flex gap-3 mb-4 flex-wrap">

                <span class="badge bg-warning fs-6 px-4 py-2">
                    <i class="fas fa-eye me-2"></i>
                    @Model.Truyen.LuotXem.ToString("N0")
                </span>

                <span class="badge bg-danger fs-6 px-4 py-2">
                    <i class="fas fa-heart me-2"></i>
                    @Model.Truyen.LuotThich.ToString("N0")
                </span>

                <span class="badge @(Model.Truyen.TrangThai == "Full" ? "bg-success" : "bg-primary") fs-6 px-4 py-2">
                    @Model.Truyen.TrangThai
                </span>

            </div>

            <!-- Actions -->
            <div class="d-flex gap-3 mb-4">

                @{
                    var chuong1 = Model.Chuongs.FirstOrDefault();
                }
                @if (Context.Session.GetInt32("MaTK") != null && chuong1 != null)
                {
                    bool daMuaChuong1 = Model.DaMuaChuong.Contains(chuong1.MaChuong);
                    @if (daMuaChuong1)
                    {
                        <a asp-controller="Truyen" asp-action="DocChuong" asp-route-id="@chuong1.MaChuong" class="btn btn-success btn-lg px-5">
                            <i class="fas fa-play me-2"></i>Đọc chương 1
                        </a>
                    }
                    else
                    {
                        <button type="button" class="btn btn-success btn-lg px-5" onclick="muaChuong(@chuong1.MaChuong); return false;">
                            <i class="fas fa-lock me-2"></i>Mua & Đọc chương 1
                        </button>
                    }
                }
                else
                {
                    <a href="/Auth/Login" class="btn btn-success btn-lg px-5">
                        <i class="fas fa-sign-in-alt me-2"></i>Đăng nhập đọc
                    </a>
                }

                <a asp-controller="Home"
                   asp-action="Index"
                   class="btn btn-outline-secondary btn-lg">
                    <i class="fas fa-arrow-left me-2"></i>Quay lại
                </a>

            </div>

            <!-- Genre -->
            <div class="mb-3">
                <small class="fw-bold text-muted me-2">
                    Thể loại:
                </small>

                <span class="badge bg-light text-dark border px-3 py-2">
                    @Model.Truyen.TheLoai
                </span>
            </div>

        </div>
    </div>

    <!-- Description -->
    <div class="row mb-5">
        <div class="col-12">

            <div class="card shadow-lg border-0">

                <div class="card-header bg-white border-0 pb-0">
                    <h3 class="mb-0 fw-bold">
                        <i class="fas fa-book-open me-2 text-primary"></i>
                        Giới thiệu
                    </h3>
                </div>

                <div class="card-body p-4">
                    <div class="text-justify lh-lg"
                         style="font-size:1.1em;line-height:1.8;">

                        @Html.Raw(Model.Truyen.MoTa.Replace("\n", "<br/>"))

                    </div>
                </div>

            </div>

        </div>
    </div>

    <!-- DANH SÁCH CHƯƠNG -->
    @if (Model.Chuongs.Any())
    {
        <div class="row">
            <div class="col-12">

                <h3 class="mb-4 fw-bold">
                    <i class="fas fa-list me-2 text-success"></i>
                    Danh sách chương (@Model.Chuongs.Count)
                </h3>

                <div class="row g-3">

                    @foreach (var chuong in Model.Chuongs)
                    {
                        bool daMua = Model.DaMuaChuong.Contains(chuong.MaChuong);

                        <div class="col-lg-4 col-md-6">
                            @if (daMua)
                            {
                                <!-- ĐÃ MUA -->
                                <a href="/Truyen/DocChuong/@chuong.MaChuong"
                                   class="text-decoration-none">
                                    <div class="card h-100 border-0 shadow-sm hover-lift">
                                        <div class="card-body p-4">
                                            <div class="mb-2">
                                                <span class="badge bg-success fs-6">
                                                    Chương @chuong.SoThuTu
                                                </span>
                                            </div>
                                            <h6 class="fw-bold mb-3">@chuong.TenChuong</h6>
                                            <div class="text-end">
                                                <button class="btn btn-success btn-sm">
                                                    <i class="fas fa-play me-1"></i>Đọc ngay
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </a>
                            }
                            else
                            {
                                <!-- CHƯA MUA -->
                                <a href="javascript:void(0)"
                                   onclick="muaChuong(@chuong.MaChuong)"
                                   class="text-decoration-none">
                                    <div class="card h-100 border-0 shadow-sm hover-lift">
                                        <div class="card-body p-4">
                                            <div class="mb-2">
                                                <span class="badge bg-primary fs-6">
                                                    Chương @chuong.SoThuTu
                                                </span>
                                            </div>
                                            <h6 class="fw-bold mb-3">@chuong.TenChuong</h6>
                                            <div class="text-end">
                                                <button class="btn btn-outline-primary btn-sm">
                                                    <i class="fas fa-lock me-1"></i>Mua & Đọc
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </a>
                            }
                        </div>
                    }

                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <i class="fas fa-info-circle me-2"></i>
            Chưa có chương nào.
        </div>
    }

</div>

<script src="~/js/mua-chuong.js"></script>

<style>
.hover-lift:hover{
    transform:translateY(-8px);
    transition:all .3s ease;
}

.text-justify{
    text-align:justify;
}

@@media (max-width:768px){

    .display-4{
        font-size:2rem !important;
    }

    .topbar{
        flex-direction:column !important;
        gap:10px !important;
    }

    .greeting{
        max-width:100% !important;
        text-align:center !important;
    }
}
</style>