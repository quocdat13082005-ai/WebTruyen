@{
    ViewData["Title"] = "Mua chương";
}

<div class="container py-5">
    <h2 class="text-center mb-4">🛒 Mua chương truyện</h2>

    @if (ViewBag.SoDu != null && ViewBag.GiaXu != null)
    {
        <div class="card shadow p-4">

            <p>
                Giá chương:
                <strong class="text-danger">
                    @ViewBag.GiaXu xu
                </strong>
            </p>

            <p>
                Số dư hiện tại:
                <strong class="text-success">
                    @ViewBag.SoDu xu
                </strong>
            </p>

            @if ((int)ViewBag.SoDu < (int)ViewBag.GiaXu)
            {
                <div class="alert alert-danger mt-3">
                    Xu không đủ! Cần thêm
                    <strong>
                        @((int)ViewBag.GiaXu - (int)ViewBag.SoDu) xu
                    </strong>
                </div>

                <a asp-controller="Home"
                   asp-action="Profile"
                   class="btn btn-warning w-100">
                    → Nạp xu ngay
                </a>
            }
            else
            {
                <form asp-controller="Truyen"
                      asp-action="MuaChuong"
                      method="post">

                    <input type="hidden"
                           name="maChuong"
                           value="@ViewBag.MaChuong" />

                    <!-- lưu trang trước -->
                    <input type="hidden"
                           name="returnUrl"
                           value="@(Context.Request.Headers["Referer"].ToString())" />

                    <button type="submit"
                            class="btn btn-success btn-lg w-100"
                            onclick="return confirm('Xác nhận mua chương này?')">

                        🛒 MUA NGAY - @ViewBag.GiaXu xu
                    </button>
                </form>

                <div class="mt-3 text-muted text-center">
                    Sau khi mua xong sẽ quay lại trang trước đó.
                </div>
            }

        </div>
    }
    else
    {
        <div class="alert alert-danger">
            Không tìm thấy thông tin chương.
        </div>
    }

    <div class="mt-4 text-center">
        <button onclick="history.back()"
                class="btn btn-secondary">
            ← Quay lại
        </button>
    </div>
</div>