@model Truyen.Models.DanhSachTruyenViewModel

@{
    ViewData["Title"] = "Danh sách truyện";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@functions {
    public static string TrangThaiHienThi(string? trangThai)
    {
        return string.IsNullOrWhiteSpace(trangThai) ? "Đang ra" : trangThai;
    }
}

<div class="container py-5">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
        <div>
            <h1 class="h3 mb-1 fw-bold">@(Model.LaKetQuaTimKiem ? "Kết quả tìm kiếm" : "Danh sách truyện")</h1>
            <p class="text-muted mb-0">
                @if (Model.LaKetQuaTimKiem)
                {
                    <span>Từ khóa: <strong>@(string.IsNullOrWhiteSpace(Model.TuKhoa) ? "Tất cả" : Model.TuKhoa)</strong></span>
                }
                else
                {
                    <span>Mỗi trang có 18 truyện, hiển thị 6 truyện trên một dòng.</span>
                }
            </p>
        </div>
        <div class="badge rounded-pill text-bg-primary px-3 py-2 fs-6">
            Tổng: @Model.TotalCount truyện
        </div>
    </div>

    @if (!Model.Truyens.Any())
    {
        <div class="alert alert-warning mb-4">Không có truyện phù hợp với từ khóa tìm kiếm.</div>

        @if (Model.LaKetQuaTimKiem && Model.TatCaTruyens.Any())
        {
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
                <div>
                    <h2 class="h4 mb-1 fw-bold">Truyện gợi ý</h2>
                    <p class="text-muted mb-0">Hiển thị 18 truyện gợi ý vì không có kết quả phù hợp.</p>
                </div>
                <div class="badge rounded-pill text-bg-secondary px-3 py-2 fs-6">
                    @Model.TatCaTruyens.Count truyện
                </div>
            </div>

            <div class="story-grid">
                @foreach (var truyen in Model.TatCaTruyens)
                {
                    <article class="story-card">
                        <a asp-controller="Truyen" asp-action="ChiTiet" asp-route-id="@truyen.MaTruyen" class="story-card__link">
                            <img src="@(string.IsNullOrWhiteSpace(truyen.AnhBia) ? "/img/default-cover.jpg" : truyen.AnhBia)"
                                 alt="@truyen.TenTruyen"
                                 class="story-card__image" />

                            <div class="story-card__body">
                                <h2 class="story-card__title">@truyen.TenTruyen</h2>
                                <p class="story-card__genre">@truyen.TheLoai</p>

                                <div class="story-card__meta">
                                    <span class="story-card__badge story-card__badge--views">
                                        <i class="fas fa-eye me-1"></i>@truyen.LuotXem
                                    </span>
                                    <span class="story-card__badge story-card__badge--likes">
                                        <i class="fas fa-heart me-1"></i>@truyen.LuotThich
                                    </span>
                                </div>

                                <span class="story-card__cta">@TrangThaiHienThi(truyen.TrangThai)</span>
                            </div>
                        </a>
                    </article>
                }
            </div>
        }
    }
    else
    {
        <div class="story-grid">
            @foreach (var truyen in Model.Truyens)
            {
                <article class="story-card">
                    <a asp-controller="Truyen" asp-action="ChiTiet" asp-route-id="@truyen.MaTruyen" class="story-card__link">
                        <img src="@(string.IsNullOrWhiteSpace(truyen.AnhBia) ? "/img/default-cover.jpg" : truyen.AnhBia)"
                             alt="@truyen.TenTruyen"
                             class="story-card__image" />

                        <div class="story-card__body">
                            <h2 class="story-card__title">@truyen.TenTruyen</h2>
                            <p class="story-card__genre">@truyen.TheLoai</p>

                            <div class="story-card__meta">
                                <span class="story-card__badge story-card__badge--views">
                                    <i class="fas fa-eye me-1"></i>@truyen.LuotXem
                                </span>
                                <span class="story-card__badge story-card__badge--likes">
                                    <i class="fas fa-heart me-1"></i>@truyen.LuotThich
                                </span>
                            </div>

                            <span class="story-card__cta">@TrangThaiHienThi(truyen.TrangThai)</span>
                        </div>
                    </a>
                </article>
            }
        </div>

        @if (Model.TotalPages > 1)
        {
            <nav aria-label="Phân trang danh sách truyện" class="mt-4">
                <ul class="pagination justify-content-center flex-wrap gap-2 mb-0">
                    <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                        <a class="page-link"
                           asp-action="@(Model.LaKetQuaTimKiem ? "TimKiem" : "DanhSachTruyen")"
                           asp-route-page="@(Model.CurrentPage - 1)"
                           asp-route-tuKhoa="@Model.TuKhoa"
                           asp-route-theLoai="@Model.TheLoai">Trước</a>
                    </li>

                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                            <a class="page-link"
                               asp-action="@(Model.LaKetQuaTimKiem ? "TimKiem" : "DanhSachTruyen")"
                               asp-route-page="@i"
                               asp-route-tuKhoa="@Model.TuKhoa"
                               asp-route-theLoai="@Model.TheLoai">@i</a>
                        </li>
                    }

                    <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                        <a class="page-link"
                           asp-action="@(Model.LaKetQuaTimKiem ? "TimKiem" : "DanhSachTruyen")"
                           asp-route-page="@(Model.CurrentPage + 1)"
                           asp-route-tuKhoa="@Model.TuKhoa"
                           asp-route-theLoai="@Model.TheLoai">Sau</a>
                    </li>
                </ul>
            </nav>
        }
    }
</div>
