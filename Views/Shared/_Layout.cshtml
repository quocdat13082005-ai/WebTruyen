﻿<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/style.css?v=1.2">

    <!-- ICON -->
    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/home-slider.js"></script>
</head>
<body>

    <!-- HEADER -->
    <header class="topbar">
        <div class="logo">
            <b><i class="fa-solid fa-book-open"></i> TRUYỆN FULL</b>
        </div>

        <nav class="menu">
            <a href="/">
                <i class="fa-solid fa-house"></i> Trang chủ
            </a>

            <a href="/Truyen/DanhSachTruyen">
                <i class="fa-solid fa-book"></i> Danh sách truyện
            </a>

            <a href="/Home/TheLoai">
                <i class="fa-solid fa-tags"></i> Thể loại
            </a>

            @if (Context.Session.GetString("VaiTro") != null)
            {
                <a href="/Home/Profile" class="me-3">
                    <i class="fa-solid fa-user-circle"></i> Thông tin cá nhân
                </a>
                <a href="/Auth/Logout">
                    <i class="fa-solid fa-sign-out-alt"></i> Đăng xuất
                </a>
            }
            else
            {
                <a href="/Auth/Login">
                    <i class="fa-solid fa-user"></i> Đăng nhập
                </a>
                <a href="/Auth/Register" style="margin-left: 10px;">
                    <i class="fa-solid fa-user-plus"></i> Đăng ký
                </a>
            }
        </nav>

        <form class="search" method="get" action="/Truyen/TimKiem">
            <input type="text" name="tuKhoa" placeholder="Tìm kiếm truyện...">
            <button type="submit" aria-label="Tìm kiếm">
                <i class="fa-solid fa-magnifying-glass"></i>
            </button>
        </form>
    </header>

    <!-- NỘI DUNG -->
    <main>
        @RenderBody()
    </main>

    <!-- FOOTER -->
    <footer>
        © 2026 WebTruyen - All rights reserved
    </footer>

    @RenderSection("Scripts", required: false)

</body>
</html>
